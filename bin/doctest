#!/usr/bin/env bash
# Fallback wrapper for running doctest without building the flake.
#
# Prefers a directly-available python3 + PyYAML; otherwise provides them via
# nix-shell. For the full, pinned environment (including `rich` for --tui) use
# the flake instead:  nix run github:logos-co/logos-doctest -- <args>
#
# Usage: doctest run <spec.yaml> [OPTIONS]
#        doctest generate <spec.yaml> [-o output.md]
#        doctest clean <dir> [OPTIONS]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENGINE="$SCRIPT_DIR/../doctest.py"

# If python3 + yaml are already available, run directly.
if python3 -c "import yaml" 2>/dev/null; then
    exec python3 "$ENGINE" "$@"
fi

# Otherwise, use nix-shell to provide them.
exec nix-shell -p python3 python3Packages.pyyaml python3Packages.rich --run \
    "python3 \"$ENGINE\" $*"
